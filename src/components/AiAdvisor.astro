---
// Il server legge la chiave dal file .env di nascosto
const apiKey = import.meta.env.PUBLIC_GEMINI_API_KEY;
---

<!-- Inseriamo la chiave in un data-attribute invisibile -->
<div id="advisor-container" class="advisor-box" data-secret={apiKey}>
  <h3>Trova il tuo Engagement Model</h3>
  <p>Raccontaci la tua sfida di business. La nostra AI ti consiglierà il pillar Arkage perfetto per te.</p>
  
  <textarea id="user-problem" rows="3" placeholder="Es. Il mio team di marketing è sovraccarico..."></textarea>
  <button id="ask-btn">Analizza la mia esigenza</button>
  
  <div id="ai-response" class="hidden"></div>
</div>

<script is:inline>
  // Lo script "pesca" la chiave dall'HTML invece di averla scritta in chiaro!
  const container = document.getElementById('advisor-container');
  const myKey = container.dataset.secret;
  
  const btn = document.getElementById('ask-btn');
  const input = document.getElementById('user-problem');
  const responseBox = document.getElementById('ai-response');

  btn.addEventListener('click', async () => {
    const userText = input.value;
    if (!userText) return;

    btn.innerText = "Elaborazione in corso...";
    responseBox.classList.remove('hidden');
    responseBox.innerHTML = "<em>L'AI sta analizzando la tua richiesta...</em>";

    const systemPrompt = `Sei un consulente della creative platform Arkage. L'utente ti dirà un problema aziendale. Rispondi in massimo 3 frasi, con tono professionale. Devi consigliare UNO dei nostri 4 pillar: Nova (team dedicato end-to-end), Talents (professionisti embedded nel team cliente), Edge (formazione e hackathon), Solutions (piattaforme custom AI). Problema dell'utente: "${userText}"`;

    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=${myKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: systemPrompt }] }]
        })
      });

      const data = await response.json();

      if (!response.ok) {
        responseBox.innerHTML = `<span style='color: red;'>Errore API Google: ${data.error?.message || 'Chiave o Modello non valido'}</span>`;
        btn.innerText = "Analizza la mia esigenza";
        return;
      }

      const aiAnswer = data.candidates[0].content.parts[0].text;
      
      responseBox.innerHTML = `<strong>Il nostro consiglio:</strong><br/><br/> ${aiAnswer}`;
      btn.innerText = "Analizza la mia esigenza";
      
    } catch (error) {
      responseBox.innerHTML = `<span style='color: red;'>Errore Tecnico: ${error.message}</span>`;
      btn.innerText = "Analizza la mia esigenza";
    }
  });
</script>

<style>
  .advisor-box { background-color: var(--ivory, #F5F0E8); padding: 2rem; border-radius: 8px; margin: 3rem 0; border: 1px solid var(--border, rgba(10,10,10,0.12)); }
  textarea { width: 100%; padding: 1rem; margin: 1rem 0; border: 1px solid #ccc; font-family: inherit; resize: vertical; }
  button { background-color: var(--black, #0A0A0A); color: white; padding: 0.8rem 1.5rem; border: none; cursor: pointer; font-weight: 600; }
  button:hover { opacity: 0.8; }
  #ai-response { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #ccc; line-height: 1.6; }
  .hidden { display: none; }
</style>