---
// src/pages/nova.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Nova — Enterprise Content · Arkage</title>
    <meta name="description" content="A dedicated flash team inside your brand — producing at volume, on sprint, with editorial consistency. The model that powers EssilorLuxottica." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --black: #0A0A0A; --ivory: #F5F0E8; --white: #FFFFFF;
        --sand: #C8B89A; --mid: #3D3D3D; --muted: #888880;
        --border: rgba(10,10,10,0.12);
        --font-d: 'Syne', sans-serif; --font-b: 'Inter', sans-serif;
        --max: 1320px; --px: clamp(1.5rem, 5vw, 5rem); --py: clamp(4rem, 8vw, 8rem);
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body { font-family: var(--font-b); background: var(--ivory); color: var(--black); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }

      /* NAV */
      nav {
        position: fixed; inset: 0 0 auto 0; z-index: 100;
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.5rem var(--px);
        background: rgba(245,240,232,0.9); backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-logo { font-family: var(--font-d); font-weight: 800; font-size: 1.2rem; letter-spacing: -0.02em; }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; font-size: 0.85rem; font-weight: 500; }
      .nav-links a { opacity: 0.55; transition: opacity 0.2s; }
      .nav-links a:hover, .nav-links a.active { opacity: 1; }
      .nav-cta { font-family: var(--font-d); font-weight: 700; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.65rem 1.4rem; background: var(--black); color: var(--ivory); transition: background 0.2s; }
      .nav-cta:hover { background: var(--mid); }

      /* HERO */
      .page-hero {
        padding-top: 10rem; padding-bottom: var(--py);
        padding-inline: var(--px); max-width: var(--max); margin-inline: auto;
        display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end;
      }
      .page-eyebrow { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; }
      .page-eyebrow::before { content: '01'; font-family: var(--font-d); font-weight: 800; font-size: 0.65rem; color: var(--sand); }
      .page-title { font-family: var(--font-d); font-weight: 800; font-size: clamp(3.5rem, 8vw, 8rem); letter-spacing: -0.04em; line-height: 0.9; }
      .page-title em { display: block; font-style: normal; font-size: clamp(1rem, 2vw, 1.5rem); font-weight: 400; letter-spacing: -0.01em; color: var(--muted); margin-top: 1rem; font-family: var(--font-b); }
      .page-standfirst { font-size: clamp(1rem, 1.5vw, 1.2rem); font-weight: 300; line-height: 1.7; color: var(--mid); border-left: 2px solid var(--sand); padding-left: 1.5rem; }

      /* CONTENT */
      .content-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .content-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; }
      .content-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); padding-top: 0.3rem; }
      .content-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: var(--mid); }
      .content-body p + p { margin-top: 1.25rem; }
      .content-body strong { font-weight: 500; color: var(--black); }

      /* WHAT WE DO */
      .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 3rem; }
      .service-card { padding: 2rem; background: var(--white); border: 1px solid var(--border); }
      .service-title { font-family: var(--font-d); font-weight: 700; font-size: 1rem; margin-bottom: 0.75rem; }
      .service-desc { font-size: 0.875rem; font-weight: 300; line-height: 1.65; color: var(--mid); }

      /* PROOF / CLIENTS */
      .proof-section { padding-block: var(--py); background: var(--black); color: var(--ivory); }
      .proof-inner { max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }
      .proof-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(245,240,232,0.35); margin-bottom: 3rem; display: flex; align-items: center; gap: 1rem; }
      .proof-label::after { content: ''; flex: 1; height: 1px; background: rgba(245,240,232,0.1); }
      .proof-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.8rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 2rem; }
      .proof-headline em { font-style: normal; color: var(--sand); }
      .proof-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: rgba(245,240,232,0.6); max-width: 70ch; }
      .proof-body p + p { margin-top: 1.25rem; }
      .proof-closing { margin-top: 2.5rem; font-family: var(--font-d); font-weight: 700; font-size: 0.9rem; color: var(--sand); font-style: italic; }

      /* IS IT FOR YOU */
      .fit-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .fit-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
      .fit-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.05; }
      .fit-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: var(--mid); }
      .fit-closing { margin-top: 2rem; font-family: var(--font-d); font-weight: 700; font-size: 1rem; color: var(--black); font-style: italic; }

      /* CTA */
      .cta-band { background: var(--sand); }
      .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; padding-block: clamp(3rem, 5vw, 5rem); max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }
      .cta-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.5rem, 3vw, 2.5rem); letter-spacing: -0.03em; line-height: 1.1; color: var(--black); }
      .cta-btn { flex-shrink: 0; font-family: var(--font-d); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 1rem 2.2rem; background: var(--black); color: var(--ivory); transition: background 0.2s; white-space: nowrap; }
      .cta-btn:hover { background: var(--mid); }

      /* FOOTER */
      footer { background: var(--black); color: var(--ivory); border-top: 1px solid rgba(245,240,232,0.08); }
      .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; padding-block: 4rem; }
      .footer-brand { font-family: var(--font-d); font-weight: 800; font-size: 1.4rem; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
      .footer-tagline { font-size: 0.85rem; font-weight: 300; color: rgba(245,240,232,0.4); line-height: 1.6; max-width: 26ch; }
      .footer-col-title { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(245,240,232,0.35); margin-bottom: 1.2rem; }
      .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
      .footer-links a { font-size: 0.875rem; font-weight: 300; opacity: 0.6; transition: opacity 0.2s; }
      .footer-links a:hover { opacity: 1; }
      .footer-bottom { border-top: 1px solid rgba(245,240,232,0.08); padding-block: 1.5rem; display: flex; justify-content: space-between; font-size: 0.7rem; color: rgba(245,240,232,0.25); }

      @media (max-width: 900px) {
        .page-hero { grid-template-columns: 1fr; gap: 2rem; }
        .content-grid { grid-template-columns: 1fr; gap: 2rem; }
        .services-grid { grid-template-columns: 1fr; }
        .fit-inner { grid-template-columns: 1fr; }
        .footer-inner { grid-template-columns: 1fr 1fr; }
        .cta-inner { flex-direction: column; align-items: flex-start; }
      }
      @media (max-width: 600px) {
        .nav-links { display: none; }
        .footer-inner { grid-template-columns: 1fr; }
      }

      @media (prefers-reduced-motion: no-preference) {
        .fade-up { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
        .fade-up.visible { opacity: 1; transform: none; }
      }
    </style>
  </head>

  <body>
    <nav>
      <a href="/" class="nav-logo">Arkage</a>
      <ul class="nav-links">
        <li><a href="/nova" class="active">Nova</a></li>
        <li><a href="/talents">Talents</a></li>
        <li><a href="/edge">Edge</a></li>
        <li><a href="/solutions">Solutions</a></li>
      </ul>
      <a href="/contact" class="nav-cta">Get in touch</a>
    </nav>

    <!-- HERO -->
    <div class="page-hero">
      <div>
        <p class="page-eyebrow">Engagement Model 01</p>
        <h1 class="page-title">
          Nova
          <em>Enterprise Content Operations</em>
        </h1>
      </div>
      <p class="page-standfirst">
        Your content operations, run as if we were part of your organization. Because, in every way that matters, we are. One accountable partner where you used to have a coordination job.
      </p>
    </div>

    <!-- THE PROBLEM -->
    <section class="content-section">
      <div class="wrap">
        <div class="content-grid fade-up">
          <p class="content-label">The problem</p>
          <div class="content-body">
            <p>Enterprise content has a problem that campaigns never had: it does not end. Product launches stack onto editorial calendars, internal communications stack onto portal updates, and every asset must respect brand guidelines, platform constraints, accessibility standards and a dozen stakeholders' opinions — every week, all year.</p>
            <p>Most companies solve this with a patchwork of vendors and an exhausted internal team gluing them together. Nova exists to replace the patchwork.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="content-section">
      <div class="wrap">
        <div class="content-grid fade-up">
          <p class="content-label">How it works</p>
          <div class="content-body">
            <p>Nova is a dedicated, stable team — project management, design, copywriting and development — that takes responsibility for a defined territory of your content operations and runs it end to end. Not a rotating cast of account people: <strong>the same group, inside your tools, your platforms and your visibility calendar, sprint after sprint.</strong></p>
            <p>We coordinate your internal stakeholders and your external suppliers, monitor the agreed schedule, produce every creative asset, control quality and implement directly in your systems.</p>
          </div>
        </div>

        <div class="services-grid fade-up">
          <div class="service-card">
            <p class="service-title">Creativity</p>
            <p class="service-desc">Concepts, design and copywriting for B2B and B2C — landing pages for global product launches, editorial features, special newsletters and executive-facing formats such as quarterly e-magazines.</p>
          </div>
          <div class="service-card">
            <p class="service-title">Campaign Amplification</p>
            <p class="service-desc">Key-visual adaptation and asset versioning at scale, brand and campaign guideline documents, playbooks, and creative assets for programmatic, CRM, paid social and in-store channels — with WCAG accessibility compliance when required.</p>
          </div>
          <div class="service-card">
            <p class="service-title">End-to-End Management</p>
            <p class="service-desc">Running the activity calendar of entire platforms, from intranet portals to corporate communication systems, including supplier and translation coordination and direct execution in enterprise marketing tools.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section class="proof-section">
      <div class="proof-inner">
        <p class="proof-label">Proven at enterprise scale</p>
        <h2 class="proof-headline fade-up">Ten years with <em>EssilorLuxottica</em>.</h2>
        <div class="proof-body fade-up">
          <p>We did not design this model on a whiteboard; it grew out of more than ten years of partnership with EssilorLuxottica, the global leader in eyewear and lens technology. For over four years a Nova team has managed activities on the Group's global B2B portal — coordinating brand managers, marketing teams and suppliers, and designing the landing pages for worldwide launches such as Ray-Ban | Meta, the Ray-Ban Reverse collaboration with Lenny Kravitz, Tiffany's collaboration with Aron Piper and Nuance Audio.</p>
          <p>The same team supports corporate internal communications for tens of thousands of employees, from weekly calendar governance to campaign execution in SAP Marketing Cloud.</p>
          <p>That experience taught us what enterprise content really demands: <strong style="color: var(--ivory)">reliability before brilliance — and brilliance anyway.</strong></p>
        </div>
        <p class="proof-closing">Engage a team. Keep the control. Lose the coordination overhead.</p>
      </div>
    </section>

    <!-- IS IT FOR YOU -->
    <section class="fit-section">
      <div class="wrap">
        <div class="fit-inner fade-up">
          <h2 class="fit-headline">Is Nova<br />for you?</h2>
          <div>
            <p class="fit-body">Nova fits organizations with a continuous, high-volume content need and a serious brand to protect: enterprise marketing departments, content factories straining under demand, groups managing multiple brands across multiple markets.</p>
            <p class="fit-body" style="margin-top: 1rem;">If your content backlog is permanent, your engagement with us should be too.</p>
            <p class="fit-closing">Engage a team. Keep the control.<br />Lose the coordination overhead.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-band">
      <div class="cta-inner">
        <h2 class="cta-headline">Tell us about<br />your content operations.</h2>
        <a href="/contact" class="cta-btn">Send us a brief</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>
            <div class="footer-brand">Arkage</div>
            <p class="footer-tagline">A creative platform — not an agency. Since 2000.</p>
          </div>
          <div>
            <p class="footer-col-title">Offer</p>
            <ul class="footer-links">
              <li><a href="/nova">Nova</a></li>
              <li><a href="/talents">Talents</a></li>
              <li><a href="/edge">Edge</a></li>
              <li><a href="/solutions">Solutions</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-title">Industries</p>
            <ul class="footer-links">
              <li><a href="/industry/fashion">Fashion</a></li>
              <li><a href="/industry/real-estate">Real Estate</a></li>
              <li><a href="/industry/non-profit">Non Profit</a></li>
              <li><a href="/industry/automotive">Automotive</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-title">Connect</p>
            <ul class="footer-links">
              <li><a href="https://instagram.com/arkage" target="_blank" rel="noopener">Instagram</a></li>
              <li><a href="https://it.linkedin.com/company/arkage" target="_blank" rel="noopener">LinkedIn</a></li>
              <li><a href="/contact">Get in touch</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} Arkage. All rights reserved.</span>
          <span>Rome · Milan</span>
        </div>
      </div>
    </footer>

    <script>
      const obs = new IntersectionObserver(
        (e) => e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('visible'); obs.unobserve(x.target); } }),
        { threshold: 0.08 }
      );
      document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
    </script>
  </body>
</html>