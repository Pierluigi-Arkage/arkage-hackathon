---
// src/pages/edge.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edge — Transformation · Arkage</title>
    <meta name="description" content="Learning designed as experience. Workshops, hackathons, gamification. Two deep verticals: AI adoption and Customer Experience." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --black: #0A0A0A; --ivory: #F5F0E8; --white: #FFFFFF;
        --sand: #C8B89A; --mid: #3D3D3D; --muted: #888880;
        --border: rgba(10,10,10,0.12);
        --font-d: 'Syne', sans-serif; --font-b: 'Inter', sans-serif;
        --max: 1320px; --px: clamp(1.5rem, 5vw, 5rem); --py: clamp(4rem, 8vw, 8rem);
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body { font-family: var(--font-b); background: var(--ivory); color: var(--black); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }

      nav { position: fixed; inset: 0 0 auto 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 1.5rem var(--px); background: rgba(245,240,232,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
      .nav-logo { font-family: var(--font-d); font-weight: 800; font-size: 1.2rem; letter-spacing: -0.02em; }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; font-size: 0.85rem; font-weight: 500; }
      .nav-links a { opacity: 0.55; transition: opacity 0.2s; }
      .nav-links a:hover, .nav-links a.active { opacity: 1; }
      .nav-cta { font-family: var(--font-d); font-weight: 700; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.65rem 1.4rem; background: var(--black); color: var(--ivory); transition: background 0.2s; }
      .nav-cta:hover { background: var(--mid); }

      .page-hero { padding-top: 10rem; padding-bottom: var(--py); padding-inline: var(--px); max-width: var(--max); margin-inline: auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; }
      .page-eyebrow { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; }
      .page-eyebrow::before { content: '03'; font-family: var(--font-d); font-weight: 800; font-size: 0.65rem; color: var(--sand); }
      .page-title { font-family: var(--font-d); font-weight: 800; font-size: clamp(3.5rem, 8vw, 8rem); letter-spacing: -0.04em; line-height: 0.9; }
      .page-title em { display: block; font-style: normal; font-size: clamp(1rem, 2vw, 1.5rem); font-weight: 400; letter-spacing: -0.01em; color: var(--muted); margin-top: 1rem; font-family: var(--font-b); }
      .page-standfirst { font-size: clamp(1rem, 1.5vw, 1.2rem); font-weight: 300; line-height: 1.7; color: var(--mid); border-left: 2px solid var(--sand); padding-left: 1.5rem; }

      .content-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .content-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; }
      .content-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); padding-top: 0.3rem; }
      .content-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: var(--mid); }
      .content-body p + p { margin-top: 1.25rem; }
      .content-body strong { font-weight: 500; color: var(--black); }

      /* FORMATS */
      .formats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-top: 3rem; border: 1px solid var(--border); }
      .format-card { background: var(--white); padding: 1.75rem; }
      .format-name { font-family: var(--font-d); font-weight: 700; font-size: 0.9rem; margin-bottom: 0.5rem; }
      .format-desc { font-size: 0.8rem; font-weight: 300; line-height: 1.6; color: var(--mid); }

      /* VERTICALS */
      .verticals-section { padding-block: var(--py); background: var(--black); color: var(--ivory); }
      .verticals-inner { max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }
      .verticals-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(245,240,232,0.35); margin-bottom: 3rem; display: flex; align-items: center; gap: 1rem; }
      .verticals-label::after { content: ''; flex: 1; height: 1px; background: rgba(245,240,232,0.1); }
      .verticals-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
      .vertical-title { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.5rem, 3vw, 2.5rem); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 1.5rem; }
      .vertical-title em { font-style: normal; color: var(--sand); }
      .vertical-body { font-size: 0.9rem; font-weight: 300; line-height: 1.8; color: rgba(245,240,232,0.6); }
      .vertical-body p + p { margin-top: 1rem; }
      .vertical-highlight { margin-top: 1.5rem; font-size: 0.8rem; font-weight: 500; color: rgba(245,240,232,0.4); letter-spacing: 0.04em; }

      .proof-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .proof-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 2rem; }
      .proof-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 2rem; }
      .proof-card { padding: 1.75rem; background: var(--white); border: 1px solid var(--border); }
      .proof-card-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem; }
      .proof-card-text { font-size: 0.875rem; font-weight: 300; line-height: 1.65; color: var(--mid); }

      .fit-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .fit-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
      .fit-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.05; }
      .fit-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: var(--mid); }
      .fit-closing { margin-top: 2rem; font-family: var(--font-d); font-weight: 700; font-size: 1rem; color: var(--black); font-style: italic; }

      .cta-band { background: var(--sand); }
      .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; padding-block: clamp(3rem, 5vw, 5rem); max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }
      .cta-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.5rem, 3vw, 2.5rem); letter-spacing: -0.03em; line-height: 1.1; color: var(--black); }
      .cta-btn { flex-shrink: 0; font-family: var(--font-d); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 1rem 2.2rem; background: var(--black); color: var(--ivory); transition: background 0.2s; white-space: nowrap; }
      .cta-btn:hover { background: var(--mid); }

      footer { background: var(--black); color: var(--ivory); border-top: 1px solid rgba(245,240,232,0.08); }
      .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; padding-block: 4rem; }
      .footer-brand { font-family: var(--font-d); font-weight: 800; font-size: 1.4rem; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
      .footer-tagline { font-size: 0.85rem; font-weight: 300; color: rgba(245,240,232,0.4); line-height: 1.6; max-width: 26ch; }
      .footer-col-title { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(245,240,232,0.35); margin-bottom: 1.2rem; }
      .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
      .footer-links a { font-size: 0.875rem; font-weight: 300; opacity: 0.6; transition: opacity 0.2s; }
      .footer-links a:hover { opacity: 1; }
      .footer-bottom { border-top: 1px solid rgba(245,240,232,0.08); padding-block: 1.5rem; display: flex; justify-content: space-between; font-size: 0.7rem; color: rgba(245,240,232,0.25); }

      @media (max-width: 900px) {
        .page-hero { grid-template-columns: 1fr; gap: 2rem; }
        .content-grid, .fit-inner { grid-template-columns: 1fr; gap: 2rem; }
        .formats-grid { grid-template-columns: 1fr 1fr; }
        .verticals-grid { grid-template-columns: 1fr; gap: 3rem; }
        .proof-grid { grid-template-columns: 1fr; }
        .footer-inner { grid-template-columns: 1fr 1fr; }
        .cta-inner { flex-direction: column; align-items: flex-start; }
      }
      @media (max-width: 600px) {
        .nav-links { display: none; }
        .formats-grid { grid-template-columns: 1fr; }
        .footer-inner { grid-template-columns: 1fr; }
      }

      @media (prefers-reduced-motion: no-preference) {
        .fade-up { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
        .fade-up.visible { opacity: 1; transform: none; }
      }
    </style>
  </head>

  <body>
    <nav>
      <a href="/" class="nav-logo">Arkage</a>
      <ul class="nav-links">
        <li><a href="/nova">Nova</a></li>
        <li><a href="/talents">Talents</a></li>
        <li><a href="/edge" class="active">Edge</a></li>
        <li><a href="/solutions">Solutions</a></li>
      </ul>
      <a href="/contact" class="nav-cta">Get in touch</a>
    </nav>

    <div class="page-hero">
      <div>
        <p class="page-eyebrow">Engagement Model 03</p>
        <h1 class="page-title">
          Edge
          <em>Transformation Programs</em>
        </h1>
      </div>
      <p class="page-standfirst">
        Enthusiasm that unlocks change. Because people transform through experiences, not through slides. Learning designed as experience — built on an agile mindset and 25 years of communication craft.
      </p>
    </div>

    <!-- THE PREMISE -->
    <section class="content-section">
      <div class="wrap">
        <div class="content-grid fade-up">
          <p class="content-label">The premise</p>
          <div class="content-body">
            <p>Every company is mid-transformation — toward AI, toward new customer expectations, toward new ways of working. And in most of them, the transformation program is a training catalogue nobody is excited about.</p>
            <p>Edge starts from a different premise, borrowed from psychologist Hugh Mackay: <strong>people are more likely to change in response to a combination of new experiences and communication than in response to communication alone.</strong> Rapid change generates resistance; information does not dissolve resistance, experience does.</p>
          </div>
        </div>

        <div class="formats-grid fade-up">
          <div class="format-card">
            <p class="format-name">Workshops</p>
            <p class="format-desc">Hands-on sessions designed around real business problems, not generic frameworks.</p>
          </div>
          <div class="format-card">
            <p class="format-name">Hackathons</p>
            <p class="format-desc">Time-compressed sprints that generate enthusiasm and prototypes in parallel.</p>
          </div>
          <div class="format-card">
            <p class="format-name">Gamification Platforms</p>
            <p class="format-desc">Structured challenges that make behavioral change measurable and sustained.</p>
          </div>
          <div class="format-card">
            <p class="format-name">Design Sprints</p>
            <p class="format-desc">Five days from problem to tested prototype, with leadership teams in the room.</p>
          </div>
          <div class="format-card">
            <p class="format-name">Internal Events</p>
            <p class="format-desc">Conventions, motivational experiences and product launches that win the attention of the people who sell.</p>
          </div>
          <div class="format-card">
            <p class="format-name">Art Thinking</p>
            <p class="format-desc">Artists and curators brought into corporate problem-solving. Developed with Cascino Progetti.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- VERTICALS -->
    <section class="verticals-section">
      <div class="verticals-inner">
        <p class="verticals-label">Two deep verticals</p>
        <div class="verticals-grid">
          <div class="fade-up">
            <h2 class="vertical-title"><em>AI</em> Adoption</h2>
            <div class="vertical-body">
              <p>Edge accompanies organizations along the whole AI adoption curve — from first curiosity to working fluency — with a cultural rather than technical approach. The entry point is the Prompt Coffee, our proprietary short-format session on the state of the art in AI, with co-creation moments that surface where AI matters for your business.</p>
              <p>Governed by the Arkage AI Manifesto and its five commitments to quality, inclusivity, transparency, responsibility and security — with an expert in the loop on every process.</p>
            </div>
            <p class="vertical-highlight">AI robotic artist · 13,000 portraits for Mercedes-Benz · Italy's first AI-powered OOH campaign for Roma Capitale · Fendi's AI-made centennial cartoon</p>
          </div>
          <div class="fade-up">
            <h2 class="vertical-title">Customer <em>Experience</em></h2>
            <div class="vertical-body">
              <p>Edge works along the CXPA® framework — from customer insights to culture and accountability. Arkage is the Italian co-founder of CXPA, supports professionals toward the CCXP® certification, and has developed CCI®, a proprietary methodology for measuring the customer-centricity of company staff, published in Harvard Business Review Italia.</p>
              <p>Programs for Reale Mutua, Alleanza Assicurazioni, Ford and Autotorino have turned customer-centricity from a poster on the wall into measured, gamified, embraced behavior.</p>
            </div>
            <p class="vertical-highlight">CXPA Italian co-founder · CCI® methodology · HBR Italia published · CCXP® certification support</p>
          </div>
        </div>
      </div>
    </section>

    <!-- IS IT FOR YOU -->
    <section class="fit-section">
      <div class="wrap">
        <div class="fit-inner fade-up">
          <h2 class="fit-headline">Is Edge<br />for you?</h2>
          <div>
            <p class="fit-body">Edge fits organizations where the gap is human, not technical: teams resisting new tools, sales networks tuning out corporate messages, cultures that need to feel a change before they adopt it.</p>
            <p class="fit-body" style="margin-top: 1rem;">For many programs, Edge can also help you access regional, national and European training funds, so the budget conversation gets easier before it starts.</p>
            <p class="fit-closing">Engage a program. Generate enthusiasm.<br />Watch the change stick.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-band">
      <div class="cta-inner">
        <h2 class="cta-headline">Tell us what<br />needs to change.</h2>
        <a href="/contact" class="cta-btn">Get in touch</a>
      </div>
    </section>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>
            <div class="footer-brand">Arkage</div>
            <p class="footer-tagline">A creative platform — not an agency. Since 2000.</p>
          </div>
          <div>
            <p class="footer-col-title">Offer</p>
            <ul class="footer-links">
              <li><a href="/nova">Nova</a></li>
              <li><a href="/talents">Talents</a></li>
              <li><a href="/edge">Edge</a></li>
              <li><a href="/solutions">Solutions</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-title">Industries</p>
            <ul class="footer-links">
              <li><a href="/industry/fashion">Fashion</a></li>
              <li><a href="/industry/real-estate">Real Estate</a></li>
              <li><a href="/industry/non-profit">Non Profit</a></li>
              <li><a href="/industry/automotive">Automotive</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-title">Connect</p>
            <ul class="footer-links">
              <li><a href="https://instagram.com/arkage" target="_blank" rel="noopener">Instagram</a></li>
              <li><a href="https://it.linkedin.com/company/arkage" target="_blank" rel="noopener">LinkedIn</a></li>
              <li><a href="/contact">Get in touch</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} Arkage. All rights reserved.</span>
          <span>Rome · Milan</span>
        </div>
      </div>
    </footer>

    <script>
      const obs = new IntersectionObserver(
        (e) => e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('visible'); obs.unobserve(x.target); } }),
        { threshold: 0.08 }
      );
      document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
    </script>
  </body>
</html>