---
// src/pages/solutions.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Solutions — AI Products & Platforms · Arkage</title>
    <meta name="description" content="Custom AI tools and platforms, designed and built with you. No off-the-shelf licenses. Starting from fast, measurable pilots." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --black: #0A0A0A; --ivory: #F5F0E8; --white: #FFFFFF;
        --sand: #C8B89A; --mid: #3D3D3D; --muted: #888880;
        --border: rgba(10,10,10,0.12);
        --font-d: 'Syne', sans-serif; --font-b: 'Inter', sans-serif;
        --max: 1320px; --px: clamp(1.5rem, 5vw, 5rem); --py: clamp(4rem, 8vw, 8rem);
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body { font-family: var(--font-b); background: var(--ivory); color: var(--black); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }

      nav { position: fixed; inset: 0 0 auto 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 1.5rem var(--px); background: rgba(245,240,232,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
      .nav-logo { font-family: var(--font-d); font-weight: 800; font-size: 1.2rem; letter-spacing: -0.02em; }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; font-size: 0.85rem; font-weight: 500; }
      .nav-links a { opacity: 0.55; transition: opacity 0.2s; }
      .nav-links a:hover, .nav-links a.active { opacity: 1; }
      .nav-cta { font-family: var(--font-d); font-weight: 700; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.65rem 1.4rem; background: var(--black); color: var(--ivory); transition: background 0.2s; }
      .nav-cta:hover { background: var(--mid); }

      .page-hero { padding-top: 10rem; padding-bottom: var(--py); padding-inline: var(--px); max-width: var(--max); margin-inline: auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; }
      .page-eyebrow { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; }
      .page-eyebrow::before { content: '04'; font-family: var(--font-d); font-weight: 800; font-size: 0.65rem; color: var(--sand); }
      .page-title { font-family: var(--font-d); font-weight: 800; font-size: clamp(2.8rem, 7vw, 7rem); letter-spacing: -0.04em; line-height: 0.9; }
      .page-title em { display: block; font-style: normal; font-size: clamp(1rem, 2vw, 1.5rem); font-weight: 400; letter-spacing: -0.01em; color: var(--muted); margin-top: 1rem; font-family: var(--font-b); }
      .page-standfirst { font-size: clamp(1rem, 1.5vw, 1.2rem); font-weight: 300; line-height: 1.7; color: var(--mid); border-left: 2px solid var(--sand); padding-left: 1.5rem; }

      .content-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .content-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; }
      .content-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); padding-top: 0.3rem; }
      .content-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: var(--mid); }
      .content-body p + p { margin-top: 1.25rem; }
      .content-body strong { font-weight: 500; color: var(--black); }

      /* JOURNEY */
      .journey-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--border); margin-top: 3rem; }
      .journey-step { padding: 2rem; border-right: 1px solid var(--border); }
      .journey-step:last-child { border-right: none; }
      .journey-step-num { font-family: var(--font-d); font-weight: 800; font-size: 2rem; color: var(--sand); letter-spacing: -0.03em; margin-bottom: 0.75rem; }
      .journey-step-title { font-family: var(--font-d); font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem; }
      .journey-step-desc { font-size: 0.85rem; font-weight: 300; line-height: 1.65; color: var(--mid); }

      /* PRODUCTS */
      .products-section { padding-block: var(--py); background: var(--black); color: var(--ivory); }
      .products-inner { max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }
      .products-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(245,240,232,0.35); margin-bottom: 3rem; display: flex; align-items: center; gap: 1rem; }
      .products-label::after { content: ''; flex: 1; height: 1px; background: rgba(245,240,232,0.1); }
      .products-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.8rem, 3.5vw, 2.8rem); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 0.75rem; }
      .products-sub { font-size: 1rem; font-weight: 300; color: rgba(245,240,232,0.5); margin-bottom: 3rem; }
      .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(245,240,232,0.08); }
      .product-card { background: var(--black); padding: 2rem; border: 1px solid rgba(245,240,232,0.08); }
      .product-name { font-family: var(--font-d); font-weight: 700; font-size: 1.1rem; color: var(--ivory); margin-bottom: 0.5rem; }
      .product-desc { font-size: 0.85rem; font-weight: 300; line-height: 1.65; color: rgba(245,240,232,0.5); }
      .product-stat { margin-top: 1.25rem; font-size: 0.75rem; font-weight: 600; color: var(--sand); letter-spacing: 0.05em; }

      /* GOVERNANCE */
      .governance-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .governance-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
      .governance-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 1.5rem; }
      .governance-headline em { font-style: normal; color: var(--sand); }
      .governance-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: var(--mid); }
      .governance-body p + p { margin-top: 1.25rem; }
      .manifesto-principles { display: flex; flex-direction: column; gap: 0; margin-top: 0; }
      .manifesto-item { padding: 1rem 0; border-bottom: 1px solid var(--border); display: flex; gap: 1rem; align-items: baseline; }
      .manifesto-item:first-child { border-top: 1px solid var(--border); }
      .manifesto-number { font-family: var(--font-d); font-weight: 700; font-size: 0.65rem; color: var(--sand); flex-shrink: 0; }
      .manifesto-title { font-family: var(--font-d); font-weight: 700; font-size: 0.9rem; }

      .fit-section { padding-block: var(--py); border-top: 1px solid var(--border); }
      .fit-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
      .fit-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.05; }
      .fit-body { font-size: 1rem; font-weight: 300; line-height: 1.8; color: var(--mid); }
      .fit-closing { margin-top: 2rem; font-family: var(--font-d); font-weight: 700; font-size: 1rem; color: var(--black); font-style: italic; }

      .cta-band { background: var(--sand); }
      .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; padding-block: clamp(3rem, 5vw, 5rem); max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }
      .cta-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.5rem, 3vw, 2.5rem); letter-spacing: -0.03em; line-height: 1.1; color: var(--black); }
      .cta-btn { flex-shrink: 0; font-family: var(--font-d); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 1rem 2.2rem; background: var(--black); color: var(--ivory); transition: background 0.2s; white-space: nowrap; }
      .cta-btn:hover { background: var(--mid); }

      footer { background: var(--black); color: var(--ivory); border-top: 1px solid rgba(245,240,232,0.08); }
      .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; padding-block: 4rem; }
      .footer-brand { font-family: var(--font-d); font-weight: 800; font-size: 1.4rem; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
      .footer-tagline { font-size: 0.85rem; font-weight: 300; color: rgba(245,240,232,0.4); line-height: 1.6; max-width: 26ch; }
      .footer-col-title { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(245,240,232,0.35); margin-bottom: 1.2rem; }
      .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
      .footer-links a { font-size: 0.875rem; font-weight: 300; opacity: 0.6; transition: opacity 0.2s; }
      .footer-links a:hover { opacity: 1; }
      .footer-bottom { border-top: 1px solid rgba(245,240,232,0.08); padding-block: 1.5rem; display: flex; justify-content: space-between; font-size: 0.7rem; color: rgba(245,240,232,0.25); }

      @media (max-width: 900px) {
        .page-hero { grid-template-columns: 1fr; gap: 2rem; }
        .content-grid, .governance-inner, .fit-inner { grid-template-columns: 1fr; gap: 2rem; }
        .journey-steps { grid-template-columns: 1fr; }
        .journey-step { border-right: none; border-bottom: 1px solid var(--border); }
        .products-grid { grid-template-columns: 1fr 1fr; }
        .footer-inner { grid-template-columns: 1fr 1fr; }
        .cta-inner { flex-direction: column; align-items: flex-start; }
      }
      @media (max-width: 600px) {
        .nav-links { display: none; }
        .products-grid { grid-template-columns: 1fr; }
        .footer-inner { grid-template-columns: 1fr; }
      }

      @media (prefers-reduced-motion: no-preference) {
        .fade-up { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
        .fade-up.visible { opacity: 1; transform: none; }
      }
    </style>
  </head>

  <body>
    <nav>
      <a href="/" class="nav-logo">Arkage</a>
      <ul class="nav-links">
        <li><a href="/nova">Nova</a></li>
        <li><a href="/talents">Talents</a></li>
        <li><a href="/edge">Edge</a></li>
        <li><a href="/solutions" class="active">Solutions</a></li>
      </ul>
      <a href="/contact" class="nav-cta">Get in touch</a>
    </nav>

    <div class="page-hero">
      <div>
        <p class="page-eyebrow">Engagement Model 04</p>
        <h1 class="page-title">
          Solutions
          <em>AI Products & Platforms</em>
        </h1>
      </div>
      <p class="page-standfirst">
        Solutions to your problems. Designed and built with you — not bought off a shelf and abandoned in a drawer. Custom AI tools, platforms and automations, with adoption engineered in from the first workshop.
      </p>
    </div>

    <!-- THE PROBLEM -->
    <section class="content-section">
      <div class="wrap">
        <div class="content-grid fade-up">
          <p class="content-label">The problem</p>
          <div class="content-body">
            <p>Every company now owns AI licenses. Far fewer own AI results. The distance between the two is rarely technological: it is the absence of someone who understands your workflow deeply enough to rebuild it around the technology.</p>
            <p>Solutions is Arkage's practice for exactly that — custom AI tools, platforms and automations, designed and built together with the teams who will use them, with adoption engineered in from the first workshop.</p>
          </div>
        </div>

        <div class="journey-steps fade-up">
          <div class="journey-step">
            <div class="journey-step-num">01</div>
            <p class="journey-step-title">Discovery</p>
            <p class="journey-step-desc">Collaborative workshops — often beginning with a Prompt Coffee — that map your processes and surface concrete automation opportunities, separating the genuinely transformative from the merely fashionable.</p>
          </div>
          <div class="journey-step">
            <div class="journey-step-num">02</div>
            <p class="journey-step-title">Enablement</p>
            <p class="journey-step-desc">Custom training programs powered by the Arkage AI Lab, a living resource of tested tools and techniques, continuously updated, so your people are ready before the technology arrives.</p>
          </div>
          <div class="journey-step">
            <div class="journey-step-num">03</div>
            <p class="journey-step-title">AI Pilots</p>
            <p class="journey-step-desc">Focused builds run on a plan-do-check-act cycle: plan a narrow pilot, execute fast, measure honestly, then embed what works into the team's real workflow. No moonshots, no eighteen-month roadmaps.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PRODUCTS -->
    <section class="products-section">
      <div class="products-inner">
        <p class="products-label">Built in-house, proven in production</p>
        <h2 class="products-headline fade-up">We test everything on the most<br />demanding client we have: ourselves.</h2>
        <p class="products-sub fade-up">Our own tools run real production, every day, for brands in luxury, fashion, tech, real estate, automotive and non-profit.</p>
        <div class="products-grid fade-up">
          <div class="product-card">
            <p class="product-name">Format Adapter</p>
            <p class="product-desc">A Figma plugin built in-house that automates the adaptation of creative assets across dozens of formats — including localization.</p>
            <p class="product-stat">~60% reduction in production time</p>
          </div>
          <div class="product-card">
            <p class="product-name">Replica</p>
            <p class="product-desc">AI-based platform that automates the creation and localization of static and video banners at volume.</p>
          </div>
          <div class="product-card">
            <p class="product-name">QA Plugin</p>
            <p class="product-desc">Validates every banner against brand and campaign guidelines — logos, text, CTAs, safe areas — before a human ever reviews it.</p>
          </div>
          <div class="product-card">
            <p class="product-name">ASAP</p>
            <p class="product-desc">Orchestrates entire production workflows from a single control panel, eliminating handover errors between teams and suppliers.</p>
          </div>
          <div class="product-card">
            <p class="product-name">Roam</p>
            <p class="product-desc">A virtual office platform for distributed teams, built for how creative work actually happens across time zones and studios.</p>
          </div>
          <div class="product-card">
            <p class="product-name">SmartRecruiter</p>
            <p class="product-desc">An AI app that matches people to briefs and roles, and maps skill gaps — used internally for the Talents practice.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- GOVERNANCE -->
    <section class="governance-section">
      <div class="wrap">
        <div class="governance-inner fade-up">
          <div>
            <h2 class="governance-headline"><em>Governance</em><br />is the feature.</h2>
            <div class="governance-body">
              <p>AI that touches your brand needs rules, and we wrote ours down before it was fashionable. The Arkage AI Manifesto commits us publicly to five principles — with an expert in the loop on every AI-augmented process.</p>
              <p>We declare AI use to clients and to their clients, we never treat it as a secret ingredient, and we evaluate the privacy and security guarantees of every tool before your data goes anywhere near it.</p>
              <p>For an enterprise buyer, that governance is not the fine print. It is the reason this works.</p>
            </div>
          </div>
          <div class="manifesto-principles">
            <div class="manifesto-item"><span class="manifesto-number">I</span><span class="manifesto-title">Quality</span></div>
            <div class="manifesto-item"><span class="manifesto-number">II</span><span class="manifesto-title">Inclusivity</span></div>
            <div class="manifesto-item"><span class="manifesto-number">III</span><span class="manifesto-title">Transparency</span></div>
            <div class="manifesto-item"><span class="manifesto-number">IV</span><span class="manifesto-title">Responsibility</span></div>
            <div class="manifesto-item"><span class="manifesto-number">V</span><span class="manifesto-title">Security</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- IS IT FOR YOU -->
    <section class="fit-section">
      <div class="wrap">
        <div class="fit-inner fade-up">
          <h2 class="fit-headline">Is Solutions<br />for you?</h2>
          <div>
            <p class="fit-body">Solutions fits teams with high-volume, rule-rich, repetitive workflows — creative production, content operations, recruiting — and leaders who want AI to show up in the numbers, not just in the town hall.</p>
            <p class="fit-closing">Engage a product. Built with you, on your problem.<br />Designed for adoption.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-band">
      <div class="cta-inner">
        <h2 class="cta-headline">Tell us where<br />the repetition is.</h2>
        <a href="/contact" class="cta-btn">Get in touch</a>
      </div>
    </section>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>
            <div class="footer-brand">Arkage</div>
            <p class="footer-tagline">A creative platform — not an agency. Since 2000.</p>
          </div>
          <div>
            <p class="footer-col-title">Offer</p>
            <ul class="footer-links">
              <li><a href="/nova">Nova</a></li>
              <li><a href="/talents">Talents</a></li>
              <li><a href="/edge">Edge</a></li>
              <li><a href="/solutions">Solutions</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-title">Industries</p>
            <ul class="footer-links">
              <li><a href="/industry/fashion">Fashion</a></li>
              <li><a href="/industry/real-estate">Real Estate</a></li>
              <li><a href="/industry/non-profit">Non Profit</a></li>
              <li><a href="/industry/automotive">Automotive</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-title">Connect</p>
            <ul class="footer-links">
              <li><a href="https://instagram.com/arkage" target="_blank" rel="noopener">Instagram</a></li>
              <li><a href="https://it.linkedin.com/company/arkage" target="_blank" rel="noopener">LinkedIn</a></li>
              <li><a href="/contact">Get in touch</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} Arkage. All rights reserved.</span>
          <span>Rome · Milan</span>
        </div>
      </div>
    </footer>

    <script>
      const obs = new IntersectionObserver(
        (e) => e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('visible'); obs.unobserve(x.target); } }),
        { threshold: 0.08 }
      );
      document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
    </script>
  </body>
</html>