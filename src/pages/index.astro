---
// src/pages/index.astro
import { sanityClient } from '../sanity.js';
import AiAdvisor from '../components/AiAdvisor.astro';
import Logo from '../components/Logo.astro';

const pillars = await sanityClient.fetch(`*[_type == "pillar"] | order(order asc) {title, tagline, description, slug}`);
const industries = await sanityClient.fetch(`*[_type == "industry"] | order(title asc) {title, description, clients, slug}`);

const fallbackPillars = [
  { title: "Nova", tagline: "A Team", description: "A dedicated team running your content operations end to end — always-on, on sprint, inside your tools.", slug: { current: "nova" } },
  { title: "Talents", tagline: "A Person", description: "AI-trained senior creatives embedded in your team. Pay only for days worked. No selection fee.", slug: { current: "talents" } },
  { title: "Edge", tagline: "A Program", description: "Training and transformation designed as experience. Two verticals: AI adoption and Customer Experience.", slug: { current: "edge" } },
  { title: "Solutions", tagline: "A Product", description: "Custom AI tools and platforms, built with you from fast, measurable pilots.", slug: { current: "solutions" } }
];

const fallbackIndustries = [
  { title: "Fashion & Luxury", description: "Branding, campaigns, photo and video production with an AI focus, digital marketing, in-store materials, social — for brands that operate at speed and at scale.", clients: ["Luxottica", "Original Marines", "Miriade", "V°73", "Teddy Group", "OVS"], slug: { current: "fashion" } },
  { title: "Real Estate", description: "Brokerage branding, residential and commercial development positioning, B2C and B2B ventures. High standing meets measurable efficiency.", clients: ["Gruppo Toscano Immobiliare", "BNP Paribas Real Estate", "SilverFir Capital"], slug: { current: "real-estate" } },
  { title: "Non Profit", description: "Strategic and creative partner for Italy's most important NGOs. Complex challenges, concrete results — built for organizations where every euro of communication has to work.", clients: ["Lega del Filo d'Oro", "AISM", "AIRC", "Telethon", "Amnesty", "Greenpeace", "Save the Children"], slug: { current: "non-profit" } },
  { title: "Automotive", description: "Product launches, retail marketing, CX programs, AI-driven content production — for manufacturers, dealer groups and mobility brands operating across Italy and internationally.", clients: ["Mercedes-Benz", "Ford", "Autotorino", "INEOS Automotive"], slug: { current: "automotive" } }
];

const displayPillars = pillars.length > 0 ? pillars : fallbackPillars;
const clientLogos = {
  fashion: [
    { src: '/clients/ray-ban.svg', alt: 'Ray-Ban' },
    { src: '/clients/fendi.svg', alt: 'Fendi' },
  ],
  'real-estate': [
    { src: '/clients/gruppo-toscano.svg', alt: 'Gruppo Toscano' },
    { src: '/clients/bnp-re.svg', alt: 'BNP Paribas Real Estate' },
  ],
  'non-profit': [
    { src: '/clients/telethon.svg', alt: 'Telethon' },
    { src: '/clients/lega-del-filo-doro.svg', alt: "Lega del Filo d'Oro" },
  ],
  automotive: [
    { src: '/clients/mercedes.svg', alt: 'Mercedes-Benz' },
    { src: '/clients/ford.svg', alt: 'Ford' },
  ],
};

const displayIndustries = industries.length > 0 ? industries : fallbackIndustries;


---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Arkage — Creative Platform</title>
    <meta name="description" content="Arkage is a creative platform — not an agency. Since 2000, four engagement models for Fashion, Real Estate, Non Profit and Automotive." />
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --black:   #0A0A0A;
        --ivory:   #F5F0E8;
        --white:   #FFFFFF;
        --sand:    #C8B89A;
        --sand-ink:#8F7340;
        --orange:  #FF6214;
        --mid:     #3D3D3D;
        --muted:   #888880;
        --border:  rgba(10,10,10,0.12);
        --font-d:  'Syne', sans-serif;
        --font-b:  'Inter', sans-serif;
        --max:     1320px;
        --px:      clamp(1.5rem, 5vw, 5rem);
        --py:      clamp(4rem, 8vw, 8rem);
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body { font-family: var(--font-b); background: var(--ivory); color: var(--black); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
      a { color: inherit; text-decoration: none; }

      .wrap { max-width: var(--max); margin-inline: auto; padding-inline: var(--px); }
      .section { padding-block: var(--py); }

      /* NAV */
      nav {
        position: fixed; inset: 0 0 auto 0; z-index: 100;
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.5rem var(--px);
        background: rgba(245,240,232,0.9); backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-logo { display: inline-flex; align-items: center; color: var(--black); }
      .nav-logo svg { display: block; height: 24px; width: auto; }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; font-size: 0.85rem; font-weight: 500; }
      .nav-links a { opacity: 0.55; transition: opacity 0.2s; }
      .nav-links a:hover { opacity: 1; }
      .nav-cta {
        font-family: var(--font-d); font-weight: 700; font-size: 0.75rem;
        letter-spacing: 0.08em; text-transform: uppercase;
        padding: 0.65rem 1.4rem; background: var(--black); color: var(--ivory);
        transition: background 0.2s;
      }
      .nav-cta:hover { background: var(--mid); }

      /* HERO */
      .hero {
        display: flex; flex-direction: column; justify-content: flex-start;
        padding-top: clamp(7rem, 9vw, 9rem); padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
        padding-inline: var(--px); max-width: var(--max); margin-inline: auto;
      }
      .hero-eyebrow {
        font-size: 0.7rem; font-weight: 500; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--muted); margin-bottom: 2rem;
        display: flex; align-items: center; gap: 1rem;
      }
      .hero-eyebrow::before { content: ''; display: block; width: 2rem; height: 1px; background: var(--muted); }
      .hero-headline {
        font-family: var(--font-d); font-weight: 800;
        font-size: clamp(3rem, 8.5vw, 9rem);
        line-height: 0.95; letter-spacing: -0.03em;
        max-width: 18ch; margin-bottom: 0;
      }
      .hero-headline em { font-style: normal; color: var(--sand); }

      /* POSITIONING ROW (below advisor) */
      .positioning-section { border-top: 1px solid var(--border); }
      .positioning-row { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(2rem, 5vw, 5rem); align-items: start; }
      .positioning-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.8rem, 3.6vw, 3rem); line-height: 1.02; letter-spacing: -0.03em; }
      .positioning-headline em { font-style: normal; color: var(--sand-ink); }
      .positioning-bottom .hero-sub { font-size: clamp(0.95rem, 1.3vw, 1.1rem); font-weight: 300; line-height: 1.65; color: var(--mid); max-width: 46ch; }
      .positioning-bottom .hero-closing { text-align: left; margin-top: 1.5rem; font-family: var(--font-d); font-weight: 700; font-size: 0.9rem; color: var(--black); letter-spacing: -0.01em; font-style: italic; }
      .hero-bottom {
        display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: end;
        border-top: 1px solid var(--border); padding-top: 2rem;
      }
      .hero-sub { font-size: clamp(0.95rem, 1.4vw, 1.15rem); font-weight: 300; line-height: 1.65; color: var(--mid); max-width: 44ch; }
      .hero-closing {
        font-family: var(--font-d); font-weight: 700; font-size: 0.9rem;
        color: var(--black); text-align: right; letter-spacing: -0.01em;
        font-style: italic;
      }

      /* SECTION LABEL */
      .section-label {
        font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--muted); margin-bottom: 3rem;
        display: flex; align-items: center; gap: 1rem;
      }
      .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

      /* PILLARS */
      .pillars-section { background: var(--white); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .pillars-header { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center; margin-bottom: 4rem; }
      .pillars-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3.2rem); letter-spacing: -0.03em; line-height: 1.05; }
      .pillars-desc { font-size: 1rem; font-weight: 300; line-height: 1.7; color: var(--mid); }
      .pillars-grid { display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid var(--border); }
      .pillar-card {
        padding: 2.5rem 2rem; border-right: 1px solid var(--border);
        display: flex; flex-direction: column; gap: 0.75rem;
        transition: background 0.25s; cursor: pointer;
      }
      .pillar-card:last-child { border-right: none; }
      .pillar-card:hover { background: var(--ivory); }
      .pillar-card:hover .pillar-arrow { opacity: 1; transform: translate(3px, -3px); }
      .pillar-number { font-family: var(--font-d); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: var(--muted); }
      .pillar-name { font-family: var(--font-d); font-weight: 800; font-size: 2rem; letter-spacing: -0.03em; line-height: 1; }
      .pillar-tagline { font-family: var(--font-d); font-size: 1.5rem; line-height: 1.05; letter-spacing: -0.01em; color: var(--sand); font-weight: 700; }
      .pillar-desc { font-size: 0.875rem; line-height: 1.7; color: var(--mid); font-weight: 300; flex: 1; margin-top: 0.5rem; }
      .pillar-arrow { font-size: 1.1rem; opacity: 0; transition: opacity 0.2s, transform 0.2s; margin-top: 1rem; align-self: flex-end; }

      /* INDUSTRIES (dark) */
      .industries-section { background: var(--black); color: var(--ivory); }
      .industries-section .section-label { color: rgba(245,240,232,0.4); justify-content: center; }
      .industries-section .section-label::after { display: none; }
      .industries-header { display: block; text-align: center; max-width: 60ch; margin: 0 auto 4rem; }
      .industries-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3.2rem); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 1.25rem; }
      .industries-desc { font-size: 1rem; font-weight: 300; line-height: 1.7; color: rgba(245,240,232,0.6); }
      .industries-list { display: flex; flex-direction: column; }
      .industry-row {
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 3rem); align-items: center;
        padding: 2.5rem 0; border-top: 1px solid rgba(245,240,232,0.12);
        cursor: pointer; transition: padding-left 0.3s ease;
      }
      .industry-row:last-child { border-bottom: 1px solid rgba(245,240,232,0.12); }
      .industry-row:hover { padding-left: 0.5rem; }
      .industry-row:hover .industry-name { color: var(--sand); }
      .industry-name { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.4rem, 2.5vw, 2.2rem); letter-spacing: -0.02em; text-align: center; color: var(--ivory); transition: color 0.2s; }
      .industry-desc { font-size: 0.875rem; line-height: 1.65; color: rgba(245,240,232,0.6); font-weight: 300; }
      .client-label { display: block; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.6rem; margin-bottom: 0.8rem; color: rgba(245,240,232,0.5); }
      .client-logos { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
      .client-logo { height: 50px; width: 60px; display: block; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.7; transition: opacity 0.2s; }
      .industry-row:hover .client-logo { opacity: 1; }
      .client-more { font-size: 0.72rem; color: rgba(245,240,232,0.45); }

      /* PLATFORM STRIP (light) */
      .platform-strip { background: var(--ivory); color: var(--black); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .platform-inner {
        display: grid; grid-template-columns: 1fr 1fr; gap: 6rem;
        align-items: center; padding-block: var(--py);
        max-width: var(--max); margin-inline: auto; padding-inline: var(--px);
      }
      .platform-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.05; color: var(--black); }
      .platform-headline em { font-style: normal; color: var(--sand-ink); }
      .platform-body { font-size: 1rem; font-weight: 300; line-height: 1.75; color: var(--mid); }
      .platform-body p + p { margin-top: 1.25rem; }
      .platform-closing { margin-top: 2rem; font-family: var(--font-d); font-weight: 700; font-size: 0.95rem; color: var(--sand-ink); font-style: italic; }

      /* CTA */
      .cta-band { background: var(--sand); }
      .cta-inner {
        display: flex; align-items: center; justify-content: space-between; gap: 2rem;
        padding-block: clamp(3rem, 6vw, 5rem);
        max-width: var(--max); margin-inline: auto; padding-inline: var(--px);
      }
      .cta-text { max-width: 46ch; }
      .cta-headline { font-family: var(--font-d); font-weight: 800; font-size: clamp(1.8rem, 4vw, 3.2rem); letter-spacing: -0.03em; line-height: 1.05; color: var(--black); max-width: 22ch; }
      .cta-sub { margin-top: 1.1rem; font-size: 0.95rem; font-weight: 300; line-height: 1.6; color: rgba(10,10,10,0.7); }
      .cta-btn {
        flex-shrink: 0; font-family: var(--font-d); font-weight: 700; font-size: 0.8rem;
        letter-spacing: 0.08em; text-transform: uppercase;
        padding: 1.1rem 2.5rem; background: var(--black); color: var(--ivory);
        transition: background 0.2s; white-space: nowrap;
      }
      .cta-btn:hover { background: var(--mid); }

      /* FOOTER */
      footer { background: var(--black); color: var(--ivory); border-top: 1px solid rgba(245,240,232,0.08); }
      .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; padding-block: 4rem; }
      .footer-brand { color: var(--ivory); margin-bottom: 0.75rem; }
      .footer-brand svg { display: block; height: 30px; width: auto; }
      .footer-tagline { font-size: 0.85rem; font-weight: 300; color: rgba(245,240,232,0.4); line-height: 1.6; max-width: 26ch; }
      .footer-bcorp { font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(245,240,232,0.25); margin-top: 1.5rem; }
      .footer-col-title { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(245,240,232,0.35); margin-bottom: 1.2rem; }
      .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
      .footer-links a { font-size: 0.875rem; font-weight: 300; opacity: 0.6; transition: opacity 0.2s; }
      .footer-links a:hover { opacity: 1; }
      .footer-bottom { border-top: 1px solid rgba(245,240,232,0.08); padding-block: 1.5rem; display: flex; justify-content: space-between; font-size: 0.7rem; color: rgba(245,240,232,0.25); }

      /* RESPONSIVE */
      @media (max-width: 1024px) {
        .pillars-grid { grid-template-columns: 1fr 1fr; }
        .pillar-card:nth-child(2) { border-right: none; }
        .pillar-card:nth-child(1), .pillar-card:nth-child(2) { border-bottom: 1px solid var(--border); }
        .platform-inner { grid-template-columns: 1fr; gap: 3rem; }
      }
      @media (max-width: 900px) {
        .positioning-row { grid-template-columns: 1fr; gap: 1.5rem; }
        .pillars-header { grid-template-columns: 1fr; }
        .industry-row { grid-template-columns: 1fr; gap: 1rem; text-align: center; }
        .industry-row:hover { padding-left: 0; }
        .industry-name { text-align: center; }
        .industry-desc { color: rgba(245,240,232,0.55); }
        .client-logos { justify-content: center; }
        .footer-inner { grid-template-columns: 1fr 1fr; }
        .cta-inner { flex-direction: column; align-items: flex-start; }
      }
      @media (max-width: 600px) {
        .nav-links { display: none; }
        .pillars-grid { grid-template-columns: 1fr; }
        .pillar-card { border-right: none; border-bottom: 1px solid var(--border); }
        .footer-inner { grid-template-columns: 1fr; }
      }

      @media (prefers-reduced-motion: no-preference) {
        .fade-up { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
        .fade-up.visible { opacity: 1; transform: none; }
      }
    </style>
    <script is:inline>
  // Finto lucchetto lato client
  const password = prompt("Accesso Riservato. Inserisci la password per visualizzare il progetto:");
  
  // Cambia "Arkage2026" con la password che preferisci
  if (password !== "Arkage2026") {
    // Se la password è sbagliata o l'utente clicca Annulla, cancelliamo tutto l'HTML
    document.head.innerHTML = "";
    document.body.innerHTML = "<div style='display:flex; justify-content:center; align-items:center; height:100vh; background-color:#0A0A0A; color:#ff4444; font-family:sans-serif; font-size:2rem; font-weight:bold;'>ACCESSO NEGATO</div>";
  }
</script>
  </head>

  <body>
    <!-- NAV -->
    <nav>
      <a href="/" class="nav-logo" aria-label="Arkage — home"><Logo height={24} /></a>
      <ul class="nav-links">
        <li><a href="/nova">Nova</a></li>
        <li><a href="/talents">Talents</a></li>
        <li><a href="/edge">Edge</a></li>
        <li><a href="/solutions">Solutions</a></li>
      </ul>
      <a href="/contact" class="nav-cta">Get in touch</a>
    </nav>

    <!-- HERO -->
    <section>
      <div class="hero">
        <p class="hero-eyebrow">Since 2000 — Rome &amp; Milan</p>
        <h1 class="hero-headline">
          You Need It. We Make It <em>Happen.</em>
        </h1>
      </div>
    </section>

    <!-- AI ADVISOR (directly below hero) -->
    <AiAdvisor />

    <!-- POSITIONING -->
    <section class="section positioning-section">
      <div class="wrap positioning-row">
        <h2 class="positioning-headline">A creative <em>platform</em>,<br />not an agency.</h2>
        <div class="positioning-bottom">
          <p class="hero-sub">
            Not an agency you brief. A platform you plug into — four ways, depending on what your business actually needs. A team, a person, a program, a product.
          </p>
          <p class="hero-closing">Expect what you wouldn't from an agency.</p>
        </div>
      </div>
    </section>

    <!-- PILLARS -->
    <section class="section pillars-section">
      <div class="wrap">
        <p class="section-label">Four Engagement Models</p>
        <div class="pillars-header">
          <h2 class="pillars-headline">Choose where<br />to plug in.</h2>
          <p class="pillars-desc">
            Each model has a different target and a different value proposition. They combine — and you can always switch levels. Start where the need is most urgent.
          </p>
        </div>
        <div class="pillars-grid">
          {displayPillars.map((p, i) => (
            <a href={`/${p.slug?.current || p.title.toLowerCase()}`} class="pillar-card fade-up">
              <span class="pillar-number">0{i + 1}</span>
              <span class="pillar-name">{p.title}</span>
              <span class="pillar-tagline">{p.tagline}</span>
              <p class="pillar-desc">{p.description}</p>
              <span class="pillar-arrow">↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- INDUSTRIES (dark) -->
    <section class="section industries-section">
      <div class="wrap">
        <div class="industries-header">
          <h2 class="industries-headline">Industries where<br />we have track record.</h2>
          <p class="industries-desc">
            We stay selective. These are the sectors where we have case studies, satisfied clients and ongoing relationships built over two decades — not verticals we claim to serve.
          </p>
        </div>
        <div class="industries-list">
          {displayIndustries.map((ind) => (
            <a href={`/industry/${ind.slug?.current || ind.title.toLowerCase().replace(/\s+/g, '-')}`} class="industry-row fade-up">
              <div class="industry-clients">
                <span class="client-label">Selected clients</span>
                <div class="client-logos">
                  {(clientLogos[ind.slug?.current] || []).map((logo) => (
                    <img class="client-logo" src={logo.src} alt={logo.alt} loading="lazy" />
                  ))}
                  <span class="client-more">and more…</span>
                </div>
              </div>
              <span class="industry-name">{ind.title}</span>
              <p class="industry-desc">{ind.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- PLATFORM STRIP (light) -->
    <section class="platform-strip">
      <div class="platform-inner">
        <h2 class="platform-headline">One platform<br />underneath <em>all four</em>.</h2>
        <div class="platform-body">
          <p>Twenty-five years of communication craft. An agile, sprint-based way of working with small flash teams instead of bloated account structures. And artificial intelligence by design — every engagement starts with the question of what AI can do for it.</p>
          <p>We are a Benefit Corporation and a certified B Corp, based in Rome and Milan, with around ninety people and an extended network of vetted creative consultants. Governed by our public AI Manifesto.</p>
          <p class="platform-closing">Start where your need is sharpest.<br />The platform does the rest.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-band">
      <div class="cta-inner">
        <div class="cta-text">
          <h2 class="cta-headline">Ready to plug into<br />a different model?</h2>
          <p class="cta-sub">Send a brief and we read it the same week. You get back the engagement model that fits — Nova, Talents, Edge or Solutions — a named contact, and the first concrete step. Not a pitch.</p>
        </div>
        <a href="/contact" class="cta-btn">Send us a brief</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>
            <div class="footer-brand"><Logo height={30} /></div>
            <p class="footer-tagline">A creative platform — not an agency. Since 2000.</p>
            <p class="footer-bcorp">Benefit Corporation · B Corp Certified</p>
          </div>
          <div>
